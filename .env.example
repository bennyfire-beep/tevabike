# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public keys (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only secret (NEVER expose to the client)
# Required for: rate limiting (bypasses RLS), admin user management
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email — Resend (https://resend.com, free tier: 3k emails/month) ─────────
# Used for: monthly salary report sent to benny on 1st of each month
# Also set the FROM domain in Resend dashboard (or use onboarding@resend.dev for testing)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cron security (Vercel auto-passes this in Authorization: Bearer header) ──
CRON_SECRET=generate-a-random-secret-here

# ─── WhatsApp / WATI (for automated attendance alerts) ───────────────────────
# Found in: app.wati.io → API → Access Token
WATI_API_URL=https://live-server-XXXXX.wati.io
WATI_API_TOKEN=your-wati-bearer-token-here

# ─── Notes ────────────────────────────────────────────────────────────────────
# 1. Copy this file to .env.local and fill in real values
# 2. .env.local is git-ignored — never commit secrets
# 3. In production (Vercel/Railway), add these as environment variables in the dashboard
# 4. Rotate SUPABASE_SERVICE_ROLE_KEY if it is ever accidentally exposed
